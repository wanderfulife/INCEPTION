# --- Domain Configuration ---
# This is the domain name for your WordPress site.
# It will be used by NGINX and WordPress.
DOMAIN_NAME=jowander.42.fr

# --- MariaDB Database Configuration ---
# IMPORTANT: These are secrets and should not be committed to a public repository.

# The password for the 'root' superuser of the database.
MYSQL_ROOT_PASSWORD=root_password_strong
# The name of the database WordPress will use.
MYSQL_DATABASE=wordpress
# The username for the WordPress database user.
MYSQL_USER=wp_user
# The password for the WordPress database user.
MYSQL_PASSWORD=wp_password_strong

# --- WordPress Administrator User ---
# Credentials for the main administrator of the WordPress site.
# The username must not be 'admin' or similar.
WP_ADMIN_USER=jowander
WP_ADMIN_PASSWORD=admin_password_strong
WP_ADMIN_EMAIL=jowander@student.42.fr

# --- Second WordPress User ---
# Credentials for a second, non-administrator user.
WP_USER_LOGIN=user2
WP_USER_PASSWORD=user2_password_strong
WP_USER_EMAIL=user2@example.com
